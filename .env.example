# jarvis-memory configuration
# Copy to .env and fill in your values

# --- Neo4j (required) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# --- Anthropic (required for LLM classifier + Graphiti) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Scoring weights (optional, defaults shown) ---
JARVIS_W_SEMANTIC=0.50
JARVIS_W_RECENCY=0.30
JARVIS_W_IMPORTANCE=0.20
JARVIS_HALF_LIFE_DAYS=90.0

# --- Hybrid search (optional) ---
JARVIS_HYBRID_ALPHA=0.7

# --- Compaction thresholds (optional) ---
JARVIS_DEDUP_DAILY=0.88
JARVIS_DEDUP_WEEKLY=0.92
JARVIS_SESSION_MAX_MEMORIES=50

# --- Lifecycle (optional) ---
JARVIS_STALE_THRESHOLD_DAYS=30

# --- API server (optional) ---
JARVIS_API_HOST=0.0.0.0
JARVIS_API_PORT=3500

# --- Hooks (optional) ---
JARVIS_MEMORY_API=http://localhost:3500
JARVIS_HOOK_MAX_MEMORIES=5
JARVIS_HOOK_TIMEOUT=3
JARVIS_AUTO_COMPACT_SESSION=true
JARVIS_GROUP_ID=  # Leave empty to auto-detect from CLAUDE.md / directory name

# --- Device identity (required for cross-device continuity) ---
JARVIS_DEVICE_ID=macbook-pro  # or "mac-mini"

# --- Conversation persistence (optional) ---
JARVIS_EPISODE_AUTO_RECORD=true
JARVIS_EPISODE_MIN_LENGTH=50
JARVIS_MAX_EPISODES_PER_SESSION=100
JARVIS_SESSION_CHAIN_DEPTH=3
JARVIS_SNAPSHOT_MAX_SIZE=5000

# --- Hooks (additional) ---
JARVIS_HOOK_MAX_EPISODES=10

# --- Classifier model (optional) ---
JARVIS_CLASSIFIER_MODEL=claude-sonnet-4-20250514

# --- Minions job queue (Run 4) ---
# SQLite file for the Minions queue. Created on first worker run.
MINIONS_DB_PATH=/Users/alexanderjmartin/Atlas/jarvis-memory/data/minions.sqlite
# Shell handler is DEFAULT DISABLED. Set to 1 only after deliberate review
# of which handlers are registered — shell jobs can run arbitrary commands.
GBRAIN_ALLOW_SHELL_JOBS=0
# Weekly-rotated JSONL audit trail for shell-job submissions. Defaults to
# ~/Atlas/jarvis-memory/audit/. Tests override this via GBRAIN_AUDIT_DIR.
# GBRAIN_AUDIT_DIR=/Users/alexanderjmartin/Atlas/jarvis-memory/audit
