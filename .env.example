# jarvis-memory configuration
# Copy this file to .env and fill in your values. `scripts/client-install.sh`
# will do this interactively for you on first install.
#
# ══════════════════════════════════════════════════════════════════
# REQUIRED
# ══════════════════════════════════════════════════════════════════

# --- Neo4j (required — the authoritative graph store) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# --- Anthropic (recommended — enables LLM-assisted search query expansion) ---
# If left blank, search falls back to keyword-only. The service still works;
# just with slightly lower recall on natural-language queries.
ANTHROPIC_API_KEY=sk-ant-...

# ══════════════════════════════════════════════════════════════════
# COMMONLY SET (optional — but useful to tune)
# ══════════════════════════════════════════════════════════════════

# --- Device identity (useful for cross-device continuity) ---
# A short name for this machine. Shown in session metadata and used when
# you run jarvis-memory on multiple boxes that share one Neo4j backend.
# Examples: "mac-mini", "laptop", "vps", "client-alpha"
JARVIS_DEVICE_ID=unknown

# --- Log location ---
# Where hook log files + audit trails go. Default: ~/.jarvis-memory/logs/
# JARVIS_LOG_DIR=/path/to/log/dir

# --- ChromaDB (optional overrides — defaults usually fine) ---
# Default is ~/.jarvis-memory/chromadb. Override if you want to co-locate
# with the repo or point at a Docker volume.
# JARVIS_CHROMADB_PATH=./chromadb
# JARVIS_CHROMADB_COLLECTION=jarvis_memory
# JARVIS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Group ID (project scoping) ---
# Episodes are tagged with a group_id so you can keep one project's memory
# from leaking into another. Leave empty to auto-detect from CLAUDE.md or
# the current directory name. Hardcode if you want a single default scope.
JARVIS_GROUP_ID=

# --- API server (optional) ---
JARVIS_API_HOST=0.0.0.0
JARVIS_API_PORT=3500

# ══════════════════════════════════════════════════════════════════
# ADVANCED (rarely touched — defaults are sensible)
# ══════════════════════════════════════════════════════════════════

# --- Scoring weights (hybrid search) ---
JARVIS_W_SEMANTIC=0.50
JARVIS_W_RECENCY=0.30
JARVIS_W_IMPORTANCE=0.20
JARVIS_HALF_LIFE_DAYS=90.0
JARVIS_HYBRID_ALPHA=0.7

# --- Compaction thresholds ---
JARVIS_DEDUP_DAILY=0.88
JARVIS_DEDUP_WEEKLY=0.92
JARVIS_SESSION_MAX_MEMORIES=50

# --- Lifecycle ---
JARVIS_STALE_THRESHOLD_DAYS=30

# --- Conversation persistence ---
JARVIS_EPISODE_AUTO_RECORD=true
JARVIS_EPISODE_MIN_LENGTH=50
JARVIS_MAX_EPISODES_PER_SESSION=100
JARVIS_SESSION_CHAIN_DEPTH=3
JARVIS_SNAPSHOT_MAX_SIZE=5000

# --- Hooks (Claude Code SessionStart + PreCompact) ---
JARVIS_MEMORY_API=http://localhost:3500
JARVIS_HOOK_MAX_MEMORIES=5
JARVIS_HOOK_MAX_EPISODES=10
JARVIS_HOOK_TIMEOUT=3
JARVIS_AUTO_COMPACT_SESSION=true

# --- Classifier model ---
JARVIS_CLASSIFIER_MODEL=claude-sonnet-4-20250514

# --- wake_up limits ---
# JARVIS_WAKE_UP_MAX_ITEMS=30
# JARVIS_WAKE_UP_MAX_TOKENS=3000

# --- Auto-detection ---
# JARVIS_ROOM_AUTO_DETECT=true

# --- Minions background job queue (optional — opt-in feature) ---
# Minions is a SQLite-backed durable job queue (ported from garrytan/gbrain).
# It runs scheduled work (daily/weekly compaction, etc.) without LLM tokens.
# To use it, run: scripts/generate_launchagents.sh --with-minion-worker (macOS)
# or: scripts/generate_systemd_units.sh --with-minion-worker (Linux)
#
# SQLite file for the queue; created on first worker run. Default: <repo>/data/minions.sqlite
# MINIONS_DB_PATH=./data/minions.sqlite
#
# Shell handler — DEFAULT DISABLED. Set to 1 only after a deliberate review
# of which handlers are registered, since shell jobs can run arbitrary commands.
# Historical name prefix (GBRAIN_*) preserved from the gbrain port.
GBRAIN_ALLOW_SHELL_JOBS=0
# Audit trail for shell-job submissions (weekly-rotated JSONL).
# Default: <repo>/audit/
# GBRAIN_AUDIT_DIR=./audit

# --- Search fallback (debug only) ---
# Set to 1 to fall back to the pre-RRF composite scorer. For A/B debugging
# or emergency rollback only.
# JARVIS_SEARCH_LEGACY=0
