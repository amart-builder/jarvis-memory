{
  "mcpServers": {
    "jarvis-memory": {
      "command": "python3",
      "args": ["-m", "mcp_server.server"],
      "cwd": "~/Atlas/jarvis-memory",
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USER": "neo4j",
        "NEO4J_PASSWORD": "your-password",
        "ANTHROPIC_API_KEY": "sk-ant-..."
      }
    }
  }
}
