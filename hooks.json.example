{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 ~/Atlas/jarvis-memory/hooks/session_start.py",
        "timeout": 3000
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 ~/Atlas/jarvis-memory/hooks/session_stop.py",
        "timeout": 5000
      }
    ]
  }
}
